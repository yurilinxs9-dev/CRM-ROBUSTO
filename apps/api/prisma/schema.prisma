generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  GERENTE
  OPERADOR
  VISUALIZADOR
}

enum LeadOrigem {
  WHATSAPP_INCOMING
  WHATSAPP_OUTGOING
  MANUAL
  IMPORT
  LANDING_PAGE
  INDICACAO
}

enum LeadTemperatura {
  FRIO
  MORNO
  QUENTE
  MUITO_QUENTE
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
}

// Quem produziu a mensagem (F-03). Decidido SEMPRE no backend, nunca pelo
// cliente: 'user' (humano via app/web/celular) bloqueia a IA na conversa;
// 'ai' (serviço de IA via API key is_ai) não bloqueia; 'system' (cadência,
// automação, integração não-IA, msg de entrada do cliente) é neutro.
enum SenderType {
  user
  ai
  system
}

model Tenant {
  id         String   @id @default(uuid())
  nome       String
  owner_id   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  prefixo_profissional      String?
  pool_enabled              Boolean @default(false)
  prefix_enabled            Boolean @default(true)
  notification_lead_minutes Int     @default(15)
  // F-02: opt-in por tenant. Só quando true (E pool_enabled) os leads novos
  // entram no rodízio round-robin por setor. Default false = comportamento atual
  // preservado (lead no pool fica sem dono).
  round_robin_enabled       Boolean @default(false)

  owner              User               @relation("TenantOwner", fields: [owner_id], references: [id])
  users              User[]             @relation("TenantMembers")
  pipelines          Pipeline[]
  stages             Stage[]
  leads              Lead[]
  messages           Message[]
  lead_activities    LeadActivity[]
  instances          WhatsappInstance[]
  user_instances     UserInstance[]
  instance_logs      InstanceLog[]
  tags               Tag[]
  lead_tags          LeadTag[]
  quick_replies      QuickReply[]
  notifications      Notification[]
  tasks              Task[]
  webhook_logs       WebhookLog[]
  push_subscriptions PushSubscription[]
  instances_hidden   InstanceHidden[]
  outbound_webhooks  OutboundWebhook[]
  api_keys           ApiKey[]
  sectors            Sector[]

  @@index([owner_id])
}

model User {
  id              String             @id @default(uuid())
  nome            String
  email           String             @unique
  senha_hash      String
  role            UserRole           @default(OPERADOR)
  avatar_url      String?
  ativo           Boolean            @default(true)
  especialidade   String?
  titulo          String?
  is_platform_admin Boolean          @default(false)
  tenant_id       String
  tenant          Tenant             @relation("TenantMembers", fields: [tenant_id], references: [id])
  // F-01: setor do colaborador. Nullable na migration p/ backfill; depois NOT NULL.
  // App exige via Zod. SetNull no delete do setor preservaria histórico, mas como
  // será NOT NULL usamos Restrict (setor só some via soft delete active=false).
  sector_id       String?
  sector          Sector?            @relation(fields: [sector_id], references: [id], onDelete: Restrict)
  owned_tenants   Tenant[]           @relation("TenantOwner")
  owned_instances WhatsappInstance[] @relation("OwnedInstances")
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  leads              Lead[]
  sent_messages      Message[]          @relation("SentBy")
  visible_messages   Message[]          @relation("VisibleTo")
  activities         LeadActivity[]
  quick_replies      QuickReply[]
  notifications      Notification[]
  user_instances     UserInstance[]
  tasks              Task[]
  push_subscriptions PushSubscription[]
  instances_hidden   InstanceHidden[]

  @@index([email])
  @@index([tenant_id])
  @@index([sector_id])
}

model Pipeline {
  id         String   @id @default(uuid())
  nome       String
  descricao  String?
  ativo      Boolean  @default(true)
  ordem      Int      @default(0)
  cor        String?  @default("#3b82f6")
  icone      String?
  arquivado  Boolean  @default(false)
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  stages     Stage[]
  leads      Lead[]

  @@unique([tenant_id, nome])
  @@index([tenant_id])
}

model Stage {
  id                  String   @id @default(uuid())
  nome                String
  cor                 String   @default("#3498DB")
  ordem               Int
  pipeline_id         String
  pipeline            Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  tenant_id           String
  tenant              Tenant   @relation(fields: [tenant_id], references: [id])
  is_won              Boolean  @default(false)
  is_lost             Boolean  @default(false)
  auto_action         Json?
  campos_obrigatorios Json?
  max_dias            Int?

  // Novos campos do Painel Dinâmico
  sla_config            Json? // { duration, unit, action, targetStageId }
  idle_alert_config     Json? // { enabled, duration, unit } — cliente sem resposta
  response_alert_config Json? // { enabled, duration, unit } — nós sem responder o cliente
  on_entry_config       Json? // { createTask, sendInitialMessage, assignResponsible }
  cadence_config        Json? // Array de degraus de cadência

  created_at DateTime @default(now())
  leads      Lead[]

  @@index([pipeline_id, ordem])
  @@index([tenant_id])
}

model Lead {
  id                 String          @id @default(uuid())
  nome               String
  telefone           String
  email              String?
  empresa            String?
  cargo              String?
  origem             LeadOrigem      @default(WHATSAPP_INCOMING)
  temperatura        LeadTemperatura @default(FRIO)
  valor_estimado     Decimal?        @db.Decimal(12, 2)
  score              Int             @default(0)
  tags               Json?           @default("[]")
  dados_custom       Json?           @default("{}")
  ultima_interacao   DateTime?
  estagio_entered_at DateTime?

  // Novos rastreadores para o Painel Dinâmico
  last_customer_message_at DateTime?
  last_agent_message_at    DateTime?
  cadence_step_index       Int       @default(0)

  proximo_followup    DateTime?
  motivo_perda        String?
  position            Float     @default(0)
  instancia_whatsapp  String
  foto_url            String?
  mensagens_nao_lidas Int       @default(0)
  pipeline_id         String
  pipeline            Pipeline  @relation(fields: [pipeline_id], references: [id])
  estagio_id          String
  estagio             Stage     @relation(fields: [estagio_id], references: [id])
  responsavel_id      String?
  responsavel         User?     @relation(fields: [responsavel_id], references: [id])
  tenant_id           String
  tenant              Tenant    @relation(fields: [tenant_id], references: [id])
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  messages   Message[]
  activities LeadActivity[]
  lead_tags  LeadTag[]
  tasks      Task[]

  assumed_at DateTime?
  is_private Boolean   @default(false)

  // F-03: trava da IA na conversa. Setado TRUE quando uma mensagem 'user'
  // (humano) é enviada. A IA checa este flag antes de responder. Só humano/admin
  // reseta para FALSE. Mensagens 'ai'/'system' não alteram.
  ai_blocked Boolean   @default(false)

  // Status de atendimento (ortogonal ao funil/stage) — usado pela API pública
  // e pelo CRM interno para marcar conversas abertas/pendentes/resolvidas.
  atendimento_status ConversationStatus @default(OPEN)

  @@unique([telefone, pipeline_id], name: "telefone_pipeline_id")
  @@index([responsavel_id, estagio_id])
  @@index([instancia_whatsapp])
  @@index([pipeline_id, estagio_id, position])
  @@index([tenant_id, pipeline_id, estagio_id, position])
  @@index([ultima_interacao])
  @@index([score])
  @@index([tenant_id])
  @@index([tenant_id, atendimento_status])
}

model Message {
  id                     String           @id @default(uuid())
  lead_id                String
  lead                   Lead             @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  instance_name          String
  whatsapp_message_id    String?
  direction              MessageDirection
  type                   MessageType      @default(TEXT)
  content                String?
  media_url              String?
  media_mimetype         String?
  media_duration_seconds Int?
  media_filename         String?
  media_size_bytes       Int?
  media_width            Int?
  media_height           Int?
  media_thumbnail_path   String?
  media_poster_path      String?
  media_waveform_peaks   Json?
  media_archived         Boolean          @default(false)
  status                 MessageStatus    @default(PENDING)
  is_internal_note       Boolean          @default(false)
  // F-03: identificação de remetente. sender_type decidido no backend (default
  // 'system' neutro). sender_id = id do humano quando 'user' (espelha
  // sent_by_user_id, mantido p/ compat). Default na migration: histórico com
  // sent_by_user_id vira 'user', resto 'system'.
  sender_type            SenderType       @default(system)
  sender_id              String?
  sent_by_user_id        String?
  sent_by                User?            @relation("SentBy", fields: [sent_by_user_id], references: [id])
  visible_to_user_id     String?
  visible_to             User?            @relation("VisibleTo", fields: [visible_to_user_id], references: [id])
  quoted_message_id      String?
  quoted_message         Message?         @relation("QuotedMessage", fields: [quoted_message_id], references: [id])
  replies                Message[]        @relation("QuotedMessage")
  metadata               Json?
  tenant_id              String
  tenant                 Tenant           @relation(fields: [tenant_id], references: [id])
  created_at             DateTime         @default(now())

  @@unique([tenant_id, whatsapp_message_id], name: "tenant_id_whatsapp_message_id")
  @@index([lead_id, created_at])
  @@index([instance_name, created_at])
  @@index([status, created_at])
  @@index([tenant_id])
  @@index([visible_to_user_id])
  @@index([media_archived, created_at])
}

model LeadActivity {
  id           String   @id @default(uuid())
  lead_id      String
  lead         Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user_id      String?
  user         User?    @relation(fields: [user_id], references: [id])
  tipo         String
  descricao    String
  dados_antes  Json?
  dados_depois Json?
  tenant_id    String
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  created_at   DateTime @default(now())

  @@index([lead_id, created_at])
  @@index([tenant_id])
}

model WhatsappInstance {
  id             String           @id @default(uuid())
  nome           String
  telefone       String?
  status         String           @default("disconnected")
  ultimo_check   DateTime?
  config         Json?
  webhook_secret String?          @unique @db.VarChar(64)
  owner_user_id  String
  owner          User             @relation("OwnedInstances", fields: [owner_user_id], references: [id])
  tenant_id      String
  tenant         Tenant           @relation(fields: [tenant_id], references: [id])
  // F-02: setor que atende este número. Define o rodízio de destino dos leads
  // que entram por esta instância. Null = cai no setor "Sem Setor" do tenant.
  sector_id      String?
  sector         Sector?          @relation(fields: [sector_id], references: [id], onDelete: SetNull)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  user_instances UserInstance[]
  instance_logs  InstanceLog[]
  hidden_by      InstanceHidden[]

  @@unique([tenant_id, nome])
  @@index([tenant_id])
}

model InstanceHidden {
  id          String           @id @default(uuid())
  user_id     String
  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  instance_id String
  instance    WhatsappInstance @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  tenant_id   String
  tenant      Tenant           @relation(fields: [tenant_id], references: [id])
  created_at  DateTime         @default(now())

  @@unique([user_id, instance_id])
  @@index([tenant_id])
}

model UserInstance {
  id          String           @id @default(uuid())
  user_id     String
  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  instance_id String
  instance    WhatsappInstance @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  tenant_id   String
  tenant      Tenant           @relation(fields: [tenant_id], references: [id])

  @@unique([user_id, instance_id])
  @@index([tenant_id])
}

model InstanceLog {
  id          String           @id @default(uuid())
  instance_id String
  instance    WhatsappInstance @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  evento      String
  detalhes    Json?
  tenant_id   String
  tenant      Tenant           @relation(fields: [tenant_id], references: [id])
  created_at  DateTime         @default(now())

  @@index([instance_id, created_at])
  @@index([tenant_id])
}

model Tag {
  id         String    @id @default(uuid())
  nome       String
  cor        String    @default("#3498DB")
  tenant_id  String
  tenant     Tenant    @relation(fields: [tenant_id], references: [id])
  created_at DateTime  @default(now())
  lead_tags  LeadTag[]

  @@unique([tenant_id, nome])
  @@index([tenant_id])
}

model LeadTag {
  id        String @id @default(uuid())
  lead_id   String
  lead      Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tag_id    String
  tag       Tag    @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([lead_id, tag_id])
  @@index([tenant_id])
}

model QuickReply {
  id         String   @id @default(uuid())
  titulo     String
  conteudo   String
  atalho     String?
  user_id    String?
  user       User?    @relation(fields: [user_id], references: [id])
  is_global  Boolean  @default(false)
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  created_at DateTime @default(now())

  @@index([atalho])
  @@index([tenant_id])
}

model WebhookLog {
  id                 String   @id @default(uuid())
  event              String
  instance           String?
  payload            Json
  processed          Boolean  @default(false)
  error              String?
  processing_time_ms Int?
  tenant_id          String?
  tenant             Tenant?  @relation(fields: [tenant_id], references: [id])
  created_at         DateTime @default(now())

  @@index([event, created_at])
  @@index([processed])
  @@index([tenant_id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  titulo     String
  conteudo   String
  tipo       String
  lida       Boolean  @default(false)
  link       String?
  // Dono do lead que originou a notificação. NULL = lead do próprio
  // destinatário ("Seus leads"); preenchido = supervisão de lead de operador
  // (agrupa "Equipe · {nome}" no sino).
  responsavel_nome String?
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  created_at DateTime @default(now())

  @@index([user_id, lida, created_at])
  @@index([tenant_id])
}

enum TaskType {
  FOLLOW_UP
  LIGACAO
  REUNIAO
  EMAIL
  VISITA
  OUTRO
}

enum TaskStatus {
  PENDENTE
  CONCLUIDA
  CANCELADA
  ATRASADA
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Task {
  id             String     @id @default(uuid())
  titulo         String
  descricao      String?
  tipo           TaskType   @default(FOLLOW_UP)
  status         TaskStatus @default(PENDENTE)
  prioridade     Prioridade @default(MEDIA)
  scheduled_at   DateTime
  completed_at   DateTime?
  duracao_min    Int?
  lead_id        String?
  lead           Lead?      @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  responsavel_id String
  responsavel    User       @relation(fields: [responsavel_id], references: [id])
  tenant_id      String
  tenant         Tenant     @relation(fields: [tenant_id], references: [id])
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  @@index([scheduled_at])
  @@index([responsavel_id, status])
  @@index([lead_id])
  @@index([tenant_id])
}

model OutboundWebhook {
  id             String            @id @default(uuid())
  tenant_id      String
  tenant         Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name           String
  url            String
  events         String[]
  active         Boolean           @default(true)
  secret         String?
  custom_headers Json?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  deliveries     WebhookDelivery[]

  @@index([tenant_id, active])
}

model WebhookDelivery {
  id            String          @id @default(uuid())
  webhook_id    String
  webhook       OutboundWebhook @relation(fields: [webhook_id], references: [id], onDelete: Cascade)
  event_type    String
  payload       Json
  status_code   Int?
  response_body String?
  success       Boolean
  error         String?
  duration_ms   Int?
  attempt       Int             @default(1)
  created_at    DateTime        @default(now())

  @@index([webhook_id, created_at])
  @@index([created_at])
}

model PushSubscription {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  user_agent String?
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([tenant_id])
}

// Chave de API para integrações externas (REST pública /api/v1).
// Múltiplas por tenant, com escopo. Guardamos apenas o hash SHA-256 do token —
// o valor em claro só é exibido uma vez, na criação (padrão GitHub PAT).
model ApiKey {
  id           String    @id @default(uuid())
  tenant_id    String
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name         String
  key_hash     String    @unique
  prefix       String
  scopes       String[]
  // F-03: marca a chave como serviço de IA. Só keys is_ai=true enviam mensagens
  // como sender_type='ai' (e respeitam ai_blocked). Demais integrações='system'.
  is_ai        Boolean   @default(false)
  active       Boolean   @default(true)
  last_used_at DateTime?
  revoked_at   DateTime?
  created_at   DateTime  @default(now())

  @@index([tenant_id, active])
  @@index([prefix])
}

// Auditoria de uso da API pública — uma linha por requisição autenticada.
// Sem FK p/ ApiKey (a chave pode ser deletada e o log deve persistir).
model ApiRequestLog {
  id          String   @id @default(uuid())
  tenant_id   String
  api_key_id  String?
  method      String
  path        String
  status_code Int
  duration_ms Int
  ip          String?
  created_at  DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([api_key_id, created_at])
}

enum AnnouncementLevel {
  INFO
  WARNING
  MAINTENANCE
}

// Avisos da plataforma (manutenção/instabilidade/recados) criados pelo admin de
// plataforma e exibidos pra todos os usuários (banner/popup). target_tenant_id
// null = todos os tenants; preenchido = só aquele tenant.
model Announcement {
  id              String            @id @default(uuid())
  title           String
  body            String
  level           AnnouncementLevel @default(INFO)
  active          Boolean           @default(true)
  target_tenant_id String?
  created_by      String
  created_at      DateTime          @default(now())
  expires_at      DateTime?

  @@index([active, created_at])
  @@index([target_tenant_id])
}

// Auditoria das ações do admin de plataforma (impersonação, broadcast, etc).
model AdminAuditLog {
  id              String   @id @default(uuid())
  admin_user_id   String
  action          String
  target_tenant_id String?
  target_user_id  String?
  detail          Json?
  ip              String?
  created_at      DateTime @default(now())

  @@index([admin_user_id, created_at])
  @@index([created_at])
}

// F-01 — Setor do colaborador. Escopo por tenant (multi-tenant). Soft delete via
// active=false: some do dropdown mas preserva o histórico dos usuários vinculados.
model Sector {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name       String
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users         User[]
  instances     WhatsappInstance[]
  queue_pointer QueuePointer?

  @@unique([tenant_id, name])
  @@index([tenant_id, active])
}

// F-02 — Ponteiro persistente do round-robin por setor. 1 linha por setor.
// Sobrevive a restart do servidor (posição da fila não se perde). O algoritmo
// faz SELECT ... FOR UPDATE nesta linha dentro de transação p/ evitar corrida.
model QueuePointer {
  sector_id     String   @id
  sector        Sector   @relation(fields: [sector_id], references: [id], onDelete: Cascade)
  current_index Int      @default(0)
  updated_at    DateTime @updatedAt
}

// F-02 — Auditoria de cada atribuição automática. Sem FK (logs persistem mesmo
// se setor/lead/usuário sumirem).
model AssignmentLog {
  id         String   @id @default(uuid())
  tenant_id  String
  sector_id  String
  lead_id    String
  user_id    String? // null = lead entrou em espera (setor sem usuários ativos)
  reason     String // 'round_robin' | 'waiting_no_agents'
  created_at DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([sector_id, created_at])
}

// ── IA NATIVA ────────────────────────────────────────────────────────────────
// Provedor do modelo. 'openai_compatible' cobre OpenAI, OpenRouter, Groq, Ollama
// e qualquer endpoint compatível (base_url + model_id livre). 'anthropic' = API
// nativa Claude. Adicionar provider novo = novo valor aqui + adapter no backend.
enum AiProvider {
  openai_compatible
  anthropic
}

// Capacidade de IA que originou uma chamada (para custo/auditoria e toggles).
enum AiFeature {
  copilot
  suggest
  autoreply
  followup
}

// Configuração de modelo de IA — escopo de PLATAFORMA (só super admin gerencia).
// O super admin cadastra QUALQUER modelo: basta provider + model_id (string livre)
// e, p/ openai_compatible, a base_url do gateway/endpoint. A chave fica cifrada
// (AES-256-GCM) e NUNCA é retornada ao client (só máscara).
model AiModelConfig {
  id          String     @id @default(uuid())
  label       String // nome amigável exibido no seletor de modelo
  provider    AiProvider
  base_url    String? // openai_compatible: URL do endpoint/gateway. null = default do provider
  model_id    String // string livre do modelo (ex: gpt-4o, claude-opus-4-8, meta-llama/...)
  api_key_enc String // chave de API cifrada em repouso (iv:tag:ciphertext base64)
  temperature Float      @default(0.7)
  max_tokens  Int        @default(1024)
  active      Boolean    @default(true)
  is_default  Boolean    @default(false)
  created_by  String
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  usage_logs AiUsageLog[]

  @@index([active])
}

// Comportamento do agente de IA — escopo de plataforma (linha única/singleton).
// system_prompt e persona moldam todas as capacidades; os *_enabled ligam/desligam
// cada recurso globalmente. default_model_id aponta o modelo usado quando o
// chamador não especifica um.
model AiAgentConfig {
  id                String   @id @default(uuid())
  system_prompt     String   @default("")
  persona           String?
  copilot_enabled   Boolean  @default(true)
  suggest_enabled   Boolean  @default(true)
  autoreply_enabled Boolean  @default(false)
  followup_enabled  Boolean  @default(false)
  default_model_id  String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

// Auditoria + base de custo de cada chamada de IA. Sem FK p/ tenant/lead (logs
// persistem mesmo se o recurso sumir). model_config_id = SetNull p/ preservar
// histórico após exclusão do modelo.
model AiUsageLog {
  id              String         @id @default(uuid())
  tenant_id       String?
  model_config_id String?
  model_config    AiModelConfig? @relation(fields: [model_config_id], references: [id], onDelete: SetNull)
  feature         AiFeature
  tokens_in       Int            @default(0)
  tokens_out      Int            @default(0)
  est_cost        Decimal?       @db.Decimal(12, 6)
  lead_id         String?
  created_at      DateTime       @default(now())

  @@index([tenant_id, created_at])
  @@index([model_config_id, created_at])
}

// ── FOLLOW-UP / BROADCAST POR IA ─────────────────────────────────────────────
enum BroadcastMode {
  template // texto fixo (com placeholder {{nome}})
  ai       // IA gera a mensagem personalizada por lead a partir de ai_instruction
}

enum BroadcastStatus {
  draft
  running
  paused
  done
  canceled
}

enum BroadcastTargetStatus {
  pending
  sent
  failed
  skipped // lead com ai_blocked, sem telefone, ou removido
}

// Disparo em massa por etapa/segmento com throttle (ex.: 1 msg a cada 5 min).
// Sem FK p/ Tenant (mesmo padrão de ApiRequestLog) — escopo por tenant_id.
model Broadcast {
  id               String          @id @default(uuid())
  tenant_id        String
  name             String
  stage_id         String? // segmenta por etapa do funil (opcional)
  segment          Json? // filtros extras (temperatura/tags) — extensível
  mode             BroadcastMode   @default(template)
  template         String? // usado quando mode=template
  ai_instruction   String? // usado quando mode=ai
  model_config_id  String? // modelo de IA (null = default da plataforma)
  throttle_seconds Int             @default(300) // espaçamento entre envios
  respect_ai_block Boolean         @default(true) // pula leads com ai_blocked
  status           BroadcastStatus @default(draft)
  created_by       String
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  last_dispatch_at DateTime? // base do throttle (quando mandou o último)

  targets BroadcastTarget[]

  @@index([tenant_id, status])
  @@index([status])
}

model BroadcastTarget {
  id           String                @id @default(uuid())
  broadcast_id String
  broadcast    Broadcast             @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)
  lead_id      String
  status       BroadcastTargetStatus @default(pending)
  sent_at      DateTime?
  error        String?
  created_at   DateTime              @default(now())

  @@index([broadcast_id, status])
}
