# ============================================================
# CRM WhatsApp — .gitignore
# ============================================================

# ---- Secrets & credentials (NEVER commit) ----
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
secrets/
secrets.json
credentials.json

# ---- Node / npm ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ---- Build outputs ----
dist/
build/
.next/
.turbo/
out/

# ---- Prisma generated (rebuilt on deploy) ----
apps/api/src/generated/

# ---- Logs ----
*.log
logs/
*.log.*

# ---- OS & editor ----
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
.vscode/settings.json

# ---- Docker volumes / runtime data ----
evolution_instances/
evolution_store/
uptime_data/
postgres_data/
backups/

# ---- AIOX / framework tooling (local only) ----
.aiox-core/
.aiox/
.claude/
.cursor/
.codex/
.gemini/
.antigravity/
.github/

# ---- Misc ----
coverage/
.nyc_output/

# ---- Arquivos locais com credenciais embutidas ----
PROMPT-MASTER-CRM.md

apps/web/tsconfig.tsbuildinfo
