# ============================================================
# CRM WhatsApp — Environment Variables
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env com credenciais reais
# ============================================================

# VPS
VPS_IP=000.000.000.000
VPS_USER=root

# Supabase (Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Upstash Redis (console.upstash.com → Redis → Details → REST API)
UPSTASH_REDIS_TLS_URL=rediss://default:PASSWORD@your-instance.upstash.io:6379

# Evolution API
EVOLUTION_API_KEY=your_strong_api_key
EVOLUTION_API_URL=http://VPS_IP:8080

# Postgres dedicado da Evolution API
POSTGRES_EVOLUTION_PASSWORD=your_strong_password

# JWT — gere com: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Webhook
WEBHOOK_SECRET=your_webhook_secret

# App
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.vercel.app
SUPABASE_STORAGE_BUCKET=crm-media
FFMPEG_PATH=/usr/bin/ffmpeg
