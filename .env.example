# ============================================================
# CRM WhatsApp — Environment Variables
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env com credenciais reais
# ============================================================

# VPS
VPS_IP=000.000.000.000
VPS_USER=root

# Supabase (Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Redis. Default: in-cluster container `crm-redis` (via docker-compose.yml).
# For local dev outside compose: redis://localhost:6379
# For TLS-managed Redis (Upstash, ElastiCache, etc): rediss://USER:PASS@HOST:PORT
REDIS_URL=redis://crm-redis:6379

# JWT — gere com: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Webhook
WEBHOOK_SECRET=your_webhook_secret

# App
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.vercel.app
SUPABASE_STORAGE_BUCKET=crm-media
FFMPEG_PATH=/usr/bin/ffmpeg

# Audio PTT (Phase 1)
# UAZAPI_PTT_FIELD: 'ptt' (default, sends type:ptt) | 'audio+ptt' (legacy fallback, sends type:audio + ptt:true)
UAZAPI_PTT_FIELD=ptt
# AUDIO_SEND_STRATEGY: 'auto' (try signed URL first, fallback to base64) | 'url' (always signed URL) | 'base64' (always data URI)
AUDIO_SEND_STRATEGY=auto
# Optional: explicit ffprobe binary path (defaults to system ffprobe)
# FFPROBE_PATH=/usr/bin/ffprobe

# Logging
LOG_LEVEL=debug

# Sentry (Phase 3) — leave SENTRY_DSN empty to disable observability
SENTRY_DSN=
SENTRY_ENV=production
# SENTRY_RELEASE=crm-api@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
